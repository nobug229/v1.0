<view class="container">
  <view class="nav-bar">
    <view class="nav-item active">餐厅列表</view>
  </view>
  
  <view class="search-bar">
    <input placeholder="搜索餐厅" class="search-input" />
    <button class="search-btn">搜索</button>
  </view>
  
  <view class="restaurant-list">
    <view class="restaurant-item" bindtap="goToRestaurant">
      <view class="restaurant-image">
        <image src="https://trae-api-cn.mchost.guru/api/ide/v1/text_to_image?prompt=campus%20restaurant%20interior&image_size=square" mode="aspectFill" />
      </view>
      <view class="restaurant-info">
        <text class="restaurant-name">校园食堂</text>
        <text class="restaurant-desc">提供各类美食，价格实惠</text>
        <view class="restaurant-tags">
          <view class="tag tag-primary">快餐</view>
          <view class="tag tag-success">优惠</view>
        </view>
        <view class="restaurant-footer">
          <text class="price">起送价：¥15</text>
          <text class="rating">评分：4.8</text>
        </view>
      </view>
    </view>
    
    <view class="restaurant-item" bindtap="goToRestaurant">
      <view class="restaurant-image">
        <image src="https://trae-api-cn.mchost.guru/api/ide/v1/text_to_image?prompt=western%20food%20restaurant&image_size=square" mode="aspectFill" />
      </view>
      <view class="restaurant-info">
        <text class="restaurant-name">西式餐厅</text>
        <text class="restaurant-desc">汉堡、披萨、意面等</text>
        <view class="restaurant-tags">
          <view class="tag tag-primary">西餐</view>
          <view class="tag tag-success">新品</view>
        </view>
        <view class="restaurant-footer">
          <text class="price">起送价：¥20</text>
          <text class="rating">评分：4.6</text>
        </view>
      </view>
    </view>
    
    <view class="restaurant-item" bindtap="goToRestaurant">
      <view class="restaurant-image">
        <image src="https://trae-api-cn.mchost.guru/api/ide/v1/text_to_image?prompt=chinese%20food%20restaurant&image_size=square" mode="aspectFill" />
      </view>
      <view class="restaurant-info">
        <text class="restaurant-name">中式餐厅</text>
        <text class="restaurant-desc">正宗中餐，口味地道</text>
        <view class="restaurant-tags">
          <view class="tag tag-primary">中餐</view>
          <view class="tag tag-success">热卖</view>
        </view>
        <view class="restaurant-footer">
          <text class="price">起送价：¥18</text>
          <text class="rating">评分：4.9</text>
        </view>
      </view>
    </view>
  </view>
</view>