.container {
  padding: 0;
}

.search-bar {
  display: flex;
  padding: 20rpx;
  background-color: white;
  border-bottom: 1rpx solid #f0f0f0;
}

.search-input {
  flex: 1;
  height: 60rpx;
  border: 1rpx solid #ddd;
  border-radius: 30rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  margin-right: 15rpx;
}

.search-btn {
  width: 100rpx;
  height: 60rpx;
  line-height: 60rpx;
  text-align: center;
  background-color: #1a73e8;
  color: white;
  border-radius: 30rpx;
  font-size: 28rpx;
  padding: 0;
}

.restaurant-list {
  padding: 20rpx;
}

.restaurant-item {
  background-color: white;
  border-radius: 10rpx;
  overflow: hidden;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.1);
}

.restaurant-image {
  width: 100%;
  height: 200rpx;
  overflow: hidden;
}

.restaurant-image image {
  width: 100%;
  height: 100%;
}

.restaurant-info {
  padding: 20rpx;
}

.restaurant-name {
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 10rpx;
  display: block;
}

.restaurant-desc {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 15rpx;
  display: block;
}

.restaurant-tags {
  margin-bottom: 15rpx;
}

.restaurant-footer {
  display: flex;
  justify-content: space-between;
  font-size: 24rpx;
  color: #999;
}

.price {
  margin-right: 30rpx;
}

.rating {
  color: #ff9800;
}