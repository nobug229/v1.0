.container {
  padding: 20rpx;
}

.post-header {
  text-align: center;
  margin-bottom: 40rpx;
}

.post-title {
  font-size: 48rpx;
  font-weight: bold;
  color: #1a73e8;
}

.post-form {
  background-color: white;
  border-radius: 15rpx;
  padding: 30rpx 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.1);
}

.form-item {
  margin-bottom: 30rpx;
}

.form-label {
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 15rpx;
  display: block;
  color: #333;
}

.radio-group {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.radio-item {
  display: flex;
  align-items: center;
  margin-right: 30rpx;
  margin-bottom: 20rpx;
}

.radio-item text {
  margin-left: 10rpx;
  font-size: 28rpx;
}

.tag-select {
  display: flex;
  flex-wrap: wrap;
  gap: 15rpx;
}

.tag-item {
  padding: 15rpx 30rpx;
  border: 2rpx solid #ddd;
  border-radius: 25rpx;
  font-size: 28rpx;
  color: #666;
  background-color: #fff;
}

.tag-item.active {
  border-color: #1a73e8;
  background-color: #1a73e8;
  color: white;
}

.error-text {
  color: #ff4d4f;
  font-size: 24rpx;
  margin-top: 10rpx;
  display: block;
}

.form-input {
  width: 100%;
  height: 80rpx;
  border: 1rpx solid #ddd;
  border-radius: 10rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
}

.form-textarea {
  width: 100%;
  height: 200rpx;
  border: 1rpx solid #ddd;
  border-radius: 10rpx;
  padding: 20rpx;
  font-size: 28rpx;
  resize: none;
}

.image-upload {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.upload-btn {
  width: 120rpx;
  height: 120rpx;
  border: 2rpx dashed #ddd;
  border-radius: 10rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  font-size: 60rpx;
  color: #999;
}

.image-preview {
  width: 120rpx;
  height: 120rpx;
  position: relative;
  border-radius: 10rpx;
  overflow: hidden;
}

.image-preview image {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.image-remove {
  position: absolute;
  top: 5rpx;
  right: 5rpx;
  width: 30rpx;
  height: 30rpx;
  border-radius: 50%;
  background-color: rgba(0, 0, 0, 0.5);
  color: white;
  display: flex;
  justify-content: center;
  align-items: center;
  font-size: 24rpx;
}

.submit-btn {
  width: 100%;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  background-color: #1a73e8;
  color: white;
  border-radius: 10rpx;
  font-size: 32rpx;
  margin-top: 40rpx;
  padding: 0;
}