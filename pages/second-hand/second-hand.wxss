.container {
  padding: 0;
  padding-bottom: 120rpx;
}

.filter-section {
  background-color: white;
  padding: 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.filter-title {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 15rpx;
  font-weight: bold;
}

.filter-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 15rpx;
}

.filter-tag {
  padding: 12rpx 25rpx;
  border: 2rpx solid #ddd;
  border-radius: 25rpx;
  font-size: 26rpx;
  color: #666;
  background-color: #fff;
}

.filter-tag.active {
  border-color: #1a73e8;
  background-color: #1a73e8;
  color: white;
}

.search-bar {
  display: flex;
  padding: 20rpx;
  background-color: white;
  border-bottom: 1rpx solid #f0f0f0;
}

.search-input {
  flex: 1;
  height: 60rpx;
  border: 1rpx solid #ddd;
  border-radius: 30rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  margin-right: 15rpx;
}

.search-btn {
  width: 100rpx;
  height: 60rpx;
  line-height: 60rpx;
  text-align: center;
  background-color: #1a73e8;
  color: white;
  border-radius: 30rpx;
  font-size: 28rpx;
  padding: 0;
}

.post-list {
  padding: 20rpx;
}

.post-item {
  display: flex;
  background-color: white;
  border-radius: 10rpx;
  overflow: hidden;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.1);
}

.post-image {
  width: 200rpx;
  height: 200rpx;
  object-fit: cover;
}

.post-info {
  flex: 1;
  padding: 20rpx;
  position: relative;
}

.post-tag-label {
  display: inline-block;
  font-size: 22rpx;
  color: #1a73e8;
  background-color: #e3f2fd;
  padding: 5rpx 12rpx;
  border-radius: 15rpx;
  margin-bottom: 8rpx;
}

.post-title {
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 10rpx;
  display: block;
}

.post-content {
  font-size: 24rpx;
  color: #666;
  margin-bottom: 20rpx;
  display: block;
  line-height: 1.5;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.post-footer {
  display: flex;
  align-items: center;
  font-size: 24rpx;
  color: #999;
}

.post-author {
  margin-right: 20rpx;
}

.post-time {
  margin-right: 20rpx;
  flex: 1;
}

.post-price {
  font-size: 28rpx;
  font-weight: bold;
  color: #ff4444;
}

.post-tag {
  font-size: 24rpx;
  color: #1a73e8;
  background-color: #e3f2fd;
  padding: 5rpx 15rpx;
  border-radius: 20rpx;
}

.post-btn {
  position: fixed;
  bottom: 100rpx;
  right: 40rpx;
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background-color: #1a73e8;
  color: white;
  display: flex;
  justify-content: center;
  align-items: center;
  font-size: 60rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.2);
  z-index: 99;
}

.empty-tip {
  text-align: center;
  padding: 100rpx 0;
  color: #999;
  font-size: 28rpx;
}