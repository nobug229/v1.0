<view class="container">
  <view class="payment-info">
    <text class="payment-title">支付订单</text>
    <view class="amount">
      <text class="amount-label">支付金额</text>
      <text class="amount-value">¥38.00</text>
    </view>
  </view>
  
  <view class="payment-methods">
    <text class="section-title">选择支付方式</text>
    <view class="payment-item active">
      <view class="payment-icon">💳</view>
      <view class="payment-info">
        <text class="payment-name">微信支付</text>
        <text class="payment-desc">推荐使用微信支付</text>
      </view>
      <view class="payment-check">✓</view>
    </view>
  </view>
  
  <view class="order-details">
    <text class="section-title">订单详情</text>
    <view class="detail-item">
      <text class="detail-label">订单编号</text>
      <text class="detail-value">20260310123456</text>
    </view>
    <view class="detail-item">
      <text class="detail-label">下单时间</text>
      <text class="detail-value">2026-03-10 12:34:56</text>
    </view>
    <view class="detail-item">
      <text class="detail-label">收货地址</text>
      <text class="detail-value">张三 13800138000 学生宿舍1栋101室</text>
    </view>
  </view>
  
  <view class="bottom-bar">
    <view class="total-price">
      <text>实付金额：</text>
      <text class="price">¥38.00</text>
    </view>
    <button class="pay-btn" bindtap="pay">立即支付</button>
  </view>
</view>