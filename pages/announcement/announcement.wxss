.container {
  padding: 20rpx;
}

.announcement-header {
  background-color: white;
  border-radius: 10rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.1);
}

.announcement-title {
  font-size: 36rpx;
  font-weight: bold;
  margin-bottom: 10rpx;
  display: block;
}

.announcement-time {
  font-size: 24rpx;
  color: #999;
  display: block;
}

.announcement-content {
  background-color: white;
  border-radius: 10rpx;
  padding: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.1);
}

.content {
  font-size: 28rpx;
  line-height: 1.5;
  color: #333;
}