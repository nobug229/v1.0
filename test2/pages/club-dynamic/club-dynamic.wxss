.container {
  padding: 20rpx;
  padding-bottom: 120rpx;
}

.club-header {
  background-color: white;
  border-radius: 10rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.1);
}

.club-title {
  font-size: 36rpx;
  font-weight: bold;
  margin-bottom: 10rpx;
  display: block;
}

.club-author {
  font-size: 24rpx;
  color: #1a73e8;
  margin-bottom: 5rpx;
  display: block;
}

.club-time {
  font-size: 24rpx;
  color: #999;
  display: block;
}

.club-content {
  background-color: white;
  border-radius: 10rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.1);
}

.club-content image {
  width: 100%;
  height: 400rpx;
  object-fit: cover;
  border-radius: 10rpx;
  margin-bottom: 20rpx;
}

.content {
  font-size: 28rpx;
  line-height: 1.5;
  color: #333;
}

.comments {
  background-color: white;
  border-radius: 10rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.1);
}

.comments-title {
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 20rpx;
  display: block;
}

.comment {
  padding: 15rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.comment:last-child {
  border-bottom: none;
}

.comment-header {
  display: flex;
  justify-content: space-between;
  margin-bottom: 10rpx;
}

.comment-name {
  font-size: 28rpx;
  font-weight: bold;
}

.comment-time {
  font-size: 24rpx;
  color: #999;
}

.comment-content {
  font-size: 28rpx;
  line-height: 1.5;
  color: #333;
}

.comment-input {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background-color: white;
  display: flex;
  align-items: center;
  padding: 20rpx;
  box-shadow: 0 -2rpx 10rpx rgba(0, 0, 0, 0.1);
  z-index: 100;
}

.input {
  flex: 1;
  height: 60rpx;
  border: 1rpx solid #ddd;
  border-radius: 30rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  margin-right: 15rpx;
}

.send-btn {
  width: 100rpx;
  height: 60rpx;
  line-height: 60rpx;
  text-align: center;
  background-color: #1a73e8;
  color: white;
  border-radius: 30rpx;
  font-size: 28rpx;
  padding: 0;
}