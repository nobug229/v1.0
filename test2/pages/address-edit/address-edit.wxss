.container {
  background-color: #f8f8f8;
  min-height: 100vh;
}

.header {
  background-color: white;
  padding: 20rpx 30rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  border-bottom: 1rpx solid #eee;
  position: sticky;
  top: 0;
  z-index: 10;
}

.header-left {
  width: 60rpx;
}

.back-btn {
  font-size: 48rpx;
  color: #333;
}

.header-title {
  font-size: 32rpx;
  font-weight: 500;
  flex: 1;
  text-align: center;
}

.header-right {
  width: 60rpx;
}

.form {
  background-color: white;
  margin-top: 20rpx;
  padding: 0 30rpx;
}

.form-item {
  padding: 30rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.form-item:last-child {
  border-bottom: none;
}

.label {
  display: block;
  font-size: 30rpx;
  color: #333;
  margin-bottom: 20rpx;
}

.input-group {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.input {
  flex: 1;
  font-size: 30rpx;
  color: #333;
  padding: 0;
}

.gender-select {
  display: flex;
  align-items: center;
  gap: 40rpx;
}

.gender-item {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.gender-circle {
  width: 32rpx;
  height: 32rpx;
  border: 2rpx solid #ddd;
  border-radius: 50%;
  background-color: white;
}

.gender-circle.checked {
  border-color: #ff8c00;
  background-color: #ff8c00;
  position: relative;
}

.gender-circle.checked::after {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 12rpx;
  height: 12rpx;
  background-color: white;
  border-radius: 50%;
}

.address-input-group {
  display: flex;
  align-items: center;
}

.location-icon {
  font-size: 28rpx;
  color: #666;
  margin-right: 10rpx;
}

.error-text {
  display: block;
  font-size: 26rpx;
  color: #ff4444;
  margin-top: 10rpx;
}

.default-switch {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.default-switch .label {
  margin-bottom: 0;
}

.bottom {
  padding: 40rpx 30rpx;
  position: sticky;
  bottom: 0;
  background-color: #f8f8f8;
  padding-bottom: 60rpx;
}

.save-btn {
  width: 100%;
  height: 88rpx;
  background: linear-gradient(135deg, #1a73e8 0%, #1557b0 100%);
  color: white;
  border-radius: 44rpx;
  font-size: 32rpx;
  font-weight: 500;
  padding: 0;
  border: none;
  box-shadow: 0 8rpx 24rpx rgba(26, 115, 232, 0.25);
}