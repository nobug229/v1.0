<view class="container">
  <view class="header">
    <text class="header-title">我的订单</text>
  </view>

  <view class="order-list">
    <view wx:for="{{orders}}" wx:key="id" class="order-card">
      <view class="order-header">
        <text class="order-number">订单号：{{item.orderNumber}}</text>
        <text class="order-time">{{formatDate(item.createTime)}}</text>
      </view>
      
      <view class="order-items">
        <view wx:for="{{item.items}}" wx:for-item="dish" wx:key="id" class="order-item">
          <text class="item-name">{{dish.name}}</text>
          <text class="item-count">x{{dish.count}}</text>
          <text class="item-price">¥{{dish.price}}</text>
        </view>
      </view>
      
      <view class="order-footer">
        <text class="customer-info">收货人：{{item.customerName}} {{item.customerPhone}}</text>
        <text class="total-price">合计：¥{{item.totalPrice}}</text>
      </view>
    </view>
    
    <view wx:if="{{orders.length === 0}}" class="empty-tip">
      <text>暂无订单</text>
    </view>
  </view>

  <view class="bottom-nav">
    <view class="nav-item" bindtap="goToMerchantHome">
      <view class="nav-icon shop"></view>
      <text class="nav-text">餐厅管理</text>
    </view>
    <view class="nav-item active">
      <view class="nav-icon profile"></view>
      <text class="nav-text">个人信息</text>
    </view>
  </view>
</view>
