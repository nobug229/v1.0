.container {
  padding: 0;
  padding-bottom: 120rpx;
  position: relative;
}

.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx;
  background-color: white;
  border-bottom: 1rpx solid #f0f0f0;
}

.title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.filter-btn {
  display: flex;
  align-items: center;
  padding: 10rpx 20rpx;
  border: 2rpx solid #1a73e8;
  border-radius: 25rpx;
  font-size: 26rpx;
  color: #1a73e8;
  background-color: white;
  cursor: pointer;
}

.arrow {
  margin-left: 8rpx;
  width: 0;
  height: 0;
  border-left: 10rpx solid transparent;
  border-right: 10rpx solid transparent;
}

.arrow.down {
  border-top: 10rpx solid #1a73e8;
}

.arrow.up {
  border-bottom: 10rpx solid #1a73e8;
}

.filter-menu {
  position: absolute;
  top: 80rpx;
  right: 20rpx;
  width: 200rpx;
  background-color: white;
  border: 1rpx solid #ddd;
  border-radius: 10rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.1);
  z-index: 100;
}

.filter-menu-item {
  padding: 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
  font-size: 26rpx;
  color: #333;
  text-align: center;
  cursor: pointer;
}

.filter-menu-item:last-child {
  border-bottom: none;
}

.filter-menu-item.active {
  color: #4CAF50;
  font-weight: bold;
}

.search-bar {
  display: flex;
  padding: 20rpx;
  background-color: white;
  border-bottom: 1rpx solid #f0f0f0;
}

.search-input {
  flex: 1;
  height: 60rpx;
  border: 1rpx solid #ddd;
  border-radius: 30rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  margin-right: 15rpx;
}

.search-btn {
  width: 100rpx;
  height: 60rpx;
  line-height: 60rpx;
  text-align: center;
  background-color: #1a73e8;
  color: white;
  border-radius: 30rpx;
  font-size: 28rpx;
  padding: 0;
}

.post-list {
  padding: 20rpx;
}

.post-item {
  display: flex;
  flex-direction: column;
  background-color: white;
  border-radius: 10rpx;
  overflow: hidden;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.1);
}

.post-item {
  display: flex;
  flex-direction: row;
}

.post-image {
  width: 200rpx;
  height: 200rpx;
  object-fit: cover;
}

.post-info {
  flex: 1;
  padding: 20rpx;
  position: relative;
}

.post-header {
  display: flex;
  align-items: center;
  margin-bottom: 8rpx;
}

.post-tag-label {
  display: inline-block;
  font-size: 22rpx;
  color: #1a73e8;
  background-color: #e3f2fd;
  padding: 5rpx 12rpx;
  border-radius: 15rpx;
  margin-right: 10rpx;
}

.pinned-label {
  display: inline-block;
  font-size: 22rpx;
  color: white;
  background-color: #ff4444;
  padding: 5rpx 12rpx;
  border-radius: 15rpx;
}

.post-title {
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 10rpx;
  display: block;
}

.post-content {
  font-size: 24rpx;
  color: #666;
  margin-bottom: 20rpx;
  display: block;
  line-height: 1.5;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.post-footer {
  display: flex;
  align-items: center;
  font-size: 24rpx;
  color: #999;
}

.post-author {
  margin-right: 20rpx;
}

.post-time {
  margin-right: 20rpx;
  flex: 1;
}

.post-price {
  font-size: 28rpx;
  font-weight: bold;
  color: #ff4444;
}

.admin-actions {
  display: flex;
  justify-content: flex-end;
  padding: 10rpx 20rpx;
  background-color: #f5f5f5;
  border-top: 1rpx solid #e0e0e0;
}

.admin-btn {
  font-size: 24rpx;
  padding: 10rpx 20rpx;
  margin-left: 10rpx;
  border-radius: 20rpx;
  border: none;
}

.delete-btn {
  background-color: #ff4444;
  color: white;
}

.pin-btn {
  background-color: #1a73e8;
  color: white;
}

.pin-btn.pinned {
  background-color: #999;
}

.fab-btn {
  position: fixed;
  bottom: 100rpx;
  right: 40rpx;
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background-color: #1a73e8;
  color: white;
  font-size: 28rpx;
  line-height: 100rpx;
  text-align: center;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.2);
  z-index: 99;
  padding: 0;
}

.empty-tip {
  text-align: center;
  padding: 100rpx 0;
  color: #999;
  font-size: 28rpx;
}
