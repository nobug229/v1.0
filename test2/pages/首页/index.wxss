.container {
  padding: 20rpx;
}

.welcome {
  margin-bottom: 40rpx;
  padding: 20rpx 0;
}

.module-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
  margin-bottom: 40rpx;
}

.module-item {
  background-color: white;
  border-radius: 15rpx;
  padding: 40rpx 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.1);
  transition: transform 0.3s ease;
}

.module-item:hover {
  transform: translateY(-5rpx);
}

.module-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.module-text {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.quick-actions {
  background-color: white;
  border-radius: 15rpx;
  padding: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.1);
}

.action-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20rpx;
}

.action-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 0;
  border-radius: 10rpx;
  background-color: #f5f5f5;
  transition: background-color 0.3s ease;
}

.action-item:hover {
  background-color: #e3f2fd;
}

.action-icon {
  font-size: 40rpx;
  margin-bottom: 10rpx;
}

.action-text {
  font-size: 24rpx;
  color: #666;
  text-align: center;
}