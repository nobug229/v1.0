<view class="container">
  <view class="welcome">
    <text style="font-size: 36rpx; font-weight: bold;">欢迎使用校园服务</text>
  </view>
  
  <view class="module-grid">
    <navigator class="module-item" url="/pages/校园美食/takeaway">
      <view class="module-icon">🍔</view>
      <text class="module-text">外卖订餐</text>
    </navigator>
    
    <navigator class="module-item" url="/pages/校园论坛/second-hand">
      <view class="module-icon">📦</view>
      <text class="module-text">二手交易</text>
    </navigator>
    
    <navigator class="module-item" url="/pages/校园资讯/campus">
      <view class="module-icon">🏫</view>
      <text class="module-text">校园生活</text>
    </navigator>
    
    <navigator class="module-item" url="/pages/个人信息/profile">
      <view class="module-icon">👤</view>
      <text class="module-text">个人中心</text>
    </navigator>
  </view>
  
  <view class="quick-actions">
    <text style="font-size: 28rpx; font-weight: bold; margin-bottom: 20rpx; display: block;">快捷功能</text>
    <view class="action-grid">
      <view class="action-item" bindtap="goToLogin">
        <view class="action-icon">🔑</view>
        <text class="action-text">登录/注册</text>
      </view>
      <view class="action-item" bindtap="showUserInfo">
        <view class="action-icon">ℹ️</view>
        <text class="action-text">用户信息</text>
      </view>
      <view class="action-item" bindtap="showAbout">
        <view class="action-icon">📝</view>
        <text class="action-text">关于我们</text>
      </view>
    </view>
  </view>
</view>