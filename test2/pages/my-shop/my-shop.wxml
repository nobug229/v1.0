<view class="container">
  <view class="header">
    <text class="header-title">我的店铺</text>
  </view>

  <view wx:if="{{!shop}}" class="empty-shop">
    <view class="empty-icon">🏪</view>
    <text class="empty-text">您还没有创建店铺</text>
    <button class="create-btn" bindtap="createShop">创建店铺</button>
  </view>

  <view wx:if="{{shop}}" class="shop-info">
    <view class="shop-card">
      <view class="shop-header">
        <view class="shop-icon">🏪</view>
        <view class="shop-name-wrapper">
          <input wx:if="{{isEditingName}}" class="shop-name-input" value="{{editingName}}" bindinput="bindNameInput" placeholder="请输入店铺名称" />
          <text wx:else class="shop-name">{{shop.name}}</text>
          <text wx:if="{{!isEditingName}}" class="edit-icon" bindtap="startEditName">✏️</text>
        </view>
      </view>
      
      <view wx:if="{{isEditingName}}" class="edit-actions">
        <button class="cancel-btn" bindtap="cancelEditName">取消</button>
        <button class="save-btn" bindtap="saveName">保存</button>
      </view>
      
      <view class="shop-footer">
        <button class="delete-btn" bindtap="deleteShop">删除店铺</button>
      </view>
    </view>
  </view>
</view>