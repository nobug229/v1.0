.container {
  padding: 20rpx;
  background-color: #f5f5f5;
  min-height: 100vh;
}

.header {
  background-color: white;
  padding: 30rpx 20rpx;
  margin-bottom: 20rpx;
  border-radius: 10rpx;
}

.header-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

.empty-shop {
  background-color: white;
  border-radius: 10rpx;
  padding: 100rpx 20rpx;
  text-align: center;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.1);
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 30rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
  margin-bottom: 40rpx;
  display: block;
}

.create-btn {
  width: 300rpx;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  background-color: #1a73e8;
  color: white;
  border-radius: 40rpx;
  font-size: 32rpx;
  padding: 0;
}

.shop-info {
  padding-bottom: 20rpx;
}

.shop-card {
  background-color: white;
  border-radius: 10rpx;
  padding: 30rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.1);
}

.shop-header {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.shop-icon {
  font-size: 80rpx;
  margin-right: 20rpx;
}

.shop-name-wrapper {
  flex: 1;
  display: flex;
  align-items: center;
}

.shop-name {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

.shop-name-input {
  flex: 1;
  font-size: 36rpx;
  font-weight: bold;
  border: 2rpx solid #1a73e8;
  border-radius: 8rpx;
  padding: 10rpx;
  margin-right: 10rpx;
}

.edit-icon {
  font-size: 28rpx;
  color: #1a73e8;
  margin-left: 10rpx;
}

.edit-actions {
  display: flex;
  justify-content: space-between;
  margin-bottom: 20rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #f0f0f0;
}

.cancel-btn,
.save-btn {
  width: 48%;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  border-radius: 10rpx;
  font-size: 32rpx;
  padding: 0;
}

.cancel-btn {
  background-color: #f5f5f5;
  color: #666;
  border: 1rpx solid #ddd;
}

.save-btn {
  background-color: #1a73e8;
  color: white;
}

.shop-footer {
  padding-top: 20rpx;
  border-top: 1rpx solid #f0f0f0;
}

.delete-btn {
  width: 100%;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  background-color: #f5f5f5;
  color: #ff4444;
  border-radius: 10rpx;
  font-size: 32rpx;
  padding: 0;
  border: 1rpx solid #ddd;
}